# ============================================
# CREATOR FORGE — Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# General
DEBUG=true

# Security
SECRET_KEY=change-this-in-production

# Database (defaults to local SQLite if not set)
# DATABASE_URL=sqlite:///creator_forge.db

# Safety Controls
DAILY_SEND_LIMIT=10

# AI
ANTHROPIC_API_KEY=
GROQ_API_KEY=
AI_MODEL=llama-3.3-70b-versatile
AI_PROVIDER=groq

# Email / Outreach
SENDGRID_API_KEY=
RESEND_API_KEY=
FROM_EMAIL=
FROM_NAME=Creator Forge Team

# SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Integration Keys
YOUTUBE_API_KEY=
INSTAGRAM_ACCESS_TOKEN=
TIKTOK_API_KEY=
APIFY_API_KEY=

# Frontend URL
FRONTEND_URL=http://localhost:3001
